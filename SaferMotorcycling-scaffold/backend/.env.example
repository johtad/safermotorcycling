# Copy this file to .env and fill in real values. NEVER commit .env or share keys in chat.
PORT=8787

# Kora — DVLA driver's licence (from merchant.korapay.com dashboard)
KORA_SECRET_KEY=
KORA_BASE=https://api.korapay.com/merchant/api/v1

# Smile ID — Ghana Card + licence (from the Smile ID portal)
SMILE_PARTNER_ID=
SMILE_API_KEY=
SMILE_ENV=sandbox

# Dojah — alternative identity provider (from app.dojah.io)
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
DOJAH_BASE=https://sandbox.dojah.io

# Supabase — persistent storage for incidents & registrations (from your Supabase project settings)
# Leave blank to run in-memory. Use the SERVICE ROLE key (server-side only; never in the browser).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# NIC Motor Insurance Database — authorized key (from NIC; docs at middoc.nic.gov.gh)
MID_API_KEY=
MID_BASE=
